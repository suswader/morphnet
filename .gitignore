# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info/

# Virtual environments
.venv

# Environment
.env

# OS files
.DS_Store

# Temp files (Chrome profiles, intermediate data)
.tmp/

# Claude Code config (personal settings)
.claude/

# Experiment results (generated per-run, not source code)
results/

# Backup files
backup/

# Log files
*.log

# Research papers (copyrighted)
papers/

# Site-specific learned data (generated at runtime)
morphnet/sites/*/tools.json
morphnet/sites/*/profile.json
morphnet/sites/*/profiles.json
morphnet/sites/*/tools_perfect.json
morphnet/sites/*/credentials.json
morphnet/sites/*/captures/
morphnet/sites/*/bundle/
morphnet/sites/*/graphs/
morphnet/sites/*/embeddings.json

# Eval run output (generated per-run, not source code)
experiments/results/

# adblock filter cache (regenerable)
cache/

# Lock file (regenerated from pyproject.toml)
uv.lock

# Old code (fully replaced by morphnet/)
evolving_interface/
experiment_results/

# v2 site-specific learned data (mirror of v1 entries)
morphnet_v2/sites/*/tools.json
morphnet_v2/sites/*/profile.json
morphnet_v2/sites/*/credentials.json
morphnet_v2/sites/*/captures/
morphnet_v2/sites/*/bundle/
morphnet_v2/sites/*/scripts/

# Nested git repos (Kushan's browser-challenge + sibling harnesses) — not part of this repo
browser-challenge/
browser-harness/

# Eval results for v2 (large, regenerable)
results/
experiments/results_v2/

# Tool-test state file (per-session, regenerable)
results/tool_test_state.json

# Python build artefacts
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.venv/

# OS files
.DS_Store
